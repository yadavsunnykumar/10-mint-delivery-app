.env
.env.*
!.env.example

# ── Node / Backend ────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Build outputs
dist/
build/
.cache/

# ── Frontend (Vite / React) ───────────────────────────────────────────────────
frontend/dist/
frontend/.cache/
frontend/node_modules/

# Bun lockfile (keep bun.lockb but ignore bun cache)
.bun/

# ── Python / AI service ───────────────────────────────────────────────────────
ai_service/venv/
ai_service/__pycache__/
ai_service/app/__pycache__/
ai_service/app/routers/__pycache__/
ai_service/app/services/__pycache__/
ai_service/app/utils/__pycache__/
ai_service/db/__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
*.egg

# Virtual environments
venv/
.venv/
env/
.env/

# Jupyter
.ipynb_checkpoints/

# ── ML / Vector store artifacts ───────────────────────────────────────────────
# Large binary model files — regenerate with build_embeddings.py / build_faiss_from_mongo.py
ai_service/app/vector_store/*.faiss
ai_service/app/vector_store/*.npy
ai_service/app/models/*.pkl
ai_service/app/models/*.joblib
ai_service/app/models/*.bin
*.pkl
*.joblib

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Docker ────────────────────────────────────────────────────────────────────
# Ignore any local override compose files
docker-compose.override.yml

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
coverage/
.nyc_output/
.eslintcache
.stylelintcache
